{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "ID of the parent conversation"
    },
    "role": {
      "type": "string",
      "enum": ["user", "assistant"],
      "description": "Who sent the message"
    },
    "content": {
      "type": "string",
      "description": "Message content"
    }
  },
  "required": ["conversation_id", "role", "content"]
}
